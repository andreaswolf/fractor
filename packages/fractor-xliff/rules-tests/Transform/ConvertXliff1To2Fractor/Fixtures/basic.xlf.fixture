<?xml version="1.0" encoding="UTF-8"?>
<xliff
	xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
	<file source-language="en" datatype="plaintext" original="messages">
		<header/>
		<body>
			<trans-unit id="label.hello">
				<source>Hello</source>
			</trans-unit>
		</body>
	</file>
</xliff>
