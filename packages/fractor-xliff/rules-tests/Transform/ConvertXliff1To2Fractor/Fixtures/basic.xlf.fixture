<xliff
	xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en">
	<file id="messages">
		<unit id="label.hello">
			<segment>
				<source>Hello</source>
			</segment>
		</unit>
	</file>
</xliff>
