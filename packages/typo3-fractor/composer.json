{
    "name": "a9f/typo3-fractor",
    "description": "TYPO3 extension for the File Read-Analyse-Change Tool. Allows modifying all sorts of files TYPO3 understands",
    "license": "MIT",
    "type": "fractor-extension",
    "keywords": [
        "dev",
        "fractor",
        "upgrade",
        "refactoring",
        "automation",
        "migration",
        "typo3"
    ],
    "authors": [
        {
            "name": "Andreas Wolf",
            "email": "dev@a-w.io",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "a9f/fractor": "^1.0",
        "a9f/fractor-extension-installer": "^1.0",
        "a9f/fractor-fluid": "^1.0",
        "a9f/fractor-htaccess": "^1.0",
        "a9f/fractor-typoscript": "^1.0",
        "a9f/fractor-xliff": "^1.0",
        "a9f/fractor-xml": "^1.0",
        "a9f/fractor-yaml": "^1.0",
        "symplify/rule-doc-generator-contracts": "^11.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "a9f\\Typo3Fractor\\": [
                "src/",
                "rules/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "a9f\\Typo3Fractor\\Tests\\": [
                "tests/",
                "rules-tests/"
            ]
        }
    },
    "bin": [
        "bin/typo3-fractor-init"
    ],
    "config": {
        "allow-plugins": {
            "a9f/fractor-extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.1-dev"
        }
    }
}
