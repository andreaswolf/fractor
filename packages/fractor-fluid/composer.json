{
    "name": "a9f/fractor-fluid",
    "description": "Fluid extension for the File Read-Analyse-Change Tool. Allows modifying Fluid files",
    "license": "MIT",
    "type": "fractor-extension",
    "keywords": [
        "dev",
        "fractor",
        "upgrade",
        "refactoring",
        "automation",
        "migration"
    ],
    "authors": [
        {
            "name": "Andreas Wolf",
            "email": "dev@a-w.io",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "a9f/fractor": "^1.0",
        "a9f/fractor-extension-installer": "^1.0",
        "nette/utils": "^4.0",
        "symplify/rule-doc-generator-contracts": "^11.2",
        "webmozart/assert": "^1.11 || ^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "a9f\\FractorFluid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "a9f\\FractorFluid\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "a9f/fractor-extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.1-dev"
        }
    }
}
