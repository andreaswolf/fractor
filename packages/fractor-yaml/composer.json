{
    "name": "a9f/fractor-yaml",
    "description": "YAML extension for the File Read-Analyse-Change Tool. Allows modifying YAML files",
    "license": "MIT",
    "type": "fractor-extension",
    "keywords": [
        "dev",
        "fractor",
        "upgrade",
        "refactoring",
        "automation",
        "migration"
    ],
    "authors": [
        {
            "name": "Andreas Wolf",
            "email": "dev@a-w.io",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "a9f/fractor": "^1.0",
        "a9f/fractor-extension-installer": "^1.0",
        "symfony/yaml": "^5.4 || ^6.4 || ^7.0 || ^8.0",
        "symplify/rule-doc-generator-contracts": "^11.2",
        "webmozart/assert": "^1.11 || ^2.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "a9f\\FractorYaml\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "a9f\\FractorYaml\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "a9f/fractor-extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.1-dev"
        }
    }
}
